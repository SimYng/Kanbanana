// StackBoard 数据模型
// 设计原则：
//  - 任务的"个人执行顺序"用 sortIndex（float）维护，拖拽时只更新被移动项
//  - priority 字段独立于 sortIndex，反映客观重要性（P0/P1/P2/P3）
//  - 任务可以挂多个语雀文档链接（YuqueLink 表）
//  - User.role 预留 admin/member，便于未来开放给员工时做权限分级

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("member") // "admin" | "member"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasksAssigned Task[]  @relation("Assignee")
  tasksCreated  Task[]  @relation("Creator")
}

/// 项目分类（如「业务」「内部工具」「AI 探索」）。
/// 用于把同领域的项目折成一组展示；分类是一个轻概念，不影响任务模型。
model ProjectCategory {
  id        String   @id @default(cuid())
  name      String
  /// 分类色点（与项目色一套色板）
  color     String   @default("gray")
  /// 默认分类（「未分类」）：禁止删除；
  /// 新建项目默认归入此处；删除其它分类时该分类下的项目会被自动迁回。
  /// 应用层 + seed / migration 共同维护「至多一条 isDefault」这一不变式。
  isDefault Boolean  @default(false)
  /// 分类的展示顺序（浮点排序键，与项目 / 任务同一套算法）
  sortIndex Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]

  @@index([sortIndex])
}

model Project {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("blue") // "blue" | "purple" | "green" | "orange" | "pink" | "yellow" | "gray"
  archived  Boolean  @default(false)
  // 默认项目（如「收集箱」）：用来收纳零散的小任务，不必为每件小事单独开项目。
  // 应用层保证至多一条，且禁止被删除 / 归档。SQLite 不便做部分唯一索引，
  // 由 seed / migration + API 层共同维护这一不变式。
  isDefault Boolean  @default(false)
  // 项目列表的展示顺序（浮点排序键），由 admin 拖拽维护，
  // 与任务的 sortIndex 同一套算法（lib/sort-index.ts）。
  sortIndex Float    @default(0)
  /// 所属分类。删除分类前必须先把项目迁走，DB 用 Restrict 兜底；
  /// API 层 DELETE 分类时会自动迁到默认分类后再删。
  categoryId String
  category   ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]

  @@index([archived, sortIndex])
  @@index([categoryId, sortIndex])
}

model Task {
  id             String   @id @default(cuid())
  title          String
  description    String?  // markdown
  projectId      String
  assigneeId     String?
  creatorId      String

  // "todo" | "doing" | "blocked" | "done"
  status         String   @default("todo")
  // "P0" | "P1" | "P2" | "P3"
  priority       String   @default("P2")

  // 个人执行顺序（浮点排序键）。拖拽时设为相邻两项的均值。
  // 作用域可视为"该 assignee 的全部任务"，跨视图共享一份顺序。
  sortIndex      Float    @default(0)

  focusedToday   Boolean  @default(false)
  blockedReason  String?
  dueDate        DateTime?
  // 任务被切换为 done 状态时由 API 写入；切回非 done 时清空。
  // 不要依赖 updatedAt 判断"今日完成"——updatedAt 会被任何字段编辑触发。
  completedAt    DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee  User?      @relation("Assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator   User       @relation("Creator", fields: [creatorId], references: [id])
  yuqueLinks YuqueLink[]

  @@index([assigneeId, sortIndex])
  @@index([projectId, status])
  @@index([status])
}

model YuqueLink {
  id        String   @id @default(cuid())
  taskId    String
  url       String
  title     String?  // 可缓存语雀文档标题
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}
