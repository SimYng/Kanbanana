// StackBoard 数据模型
// 设计原则：
//  - 任务的执行顺序用 sortIndex（float）维护，拖拽时只更新被移动项
//  - 任务可以挂多个语雀文档链接（YuqueLink 表）
//  - User.role 预留 admin/member，便于未来开放给员工时做权限分级

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("member") // "admin" | "member"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasksAssigned Task[]  @relation("Assignee")
  tasksCreated  Task[]  @relation("Creator")
}

/// 项目分类（如「业务」「内部工具」「AI 探索」）。
/// 用于把同领域的项目折成一组展示；分类是一个轻概念，不影响任务模型。
model ProjectCategory {
  id        String   @id @default(cuid())
  name      String
  /// 默认分类（「未分类」）：禁止删除；
  /// 新建项目默认归入此处；删除其它分类时该分类下的项目会被自动迁回。
  /// 应用层 + seed / migration 共同维护「至多一条 isDefault」这一不变式。
  isDefault Boolean  @default(false)
  /// 分类的展示顺序（浮点排序键，与项目 / 任务同一套算法）
  sortIndex Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]

  @@index([sortIndex])
}

model Project {
  id        String   @id @default(cuid())
  name      String
  archived  Boolean  @default(false)
  // 默认项目（如「收集箱」）：用来收纳零散的小任务，不必为每件小事单独开项目。
  // 应用层保证至多一条，且禁止被删除 / 归档。SQLite 不便做部分唯一索引，
  // 由 seed / migration + API 层共同维护这一不变式。
  isDefault Boolean  @default(false)
  // 项目列表的展示顺序（浮点排序键），由 admin 拖拽维护，
  // 与任务的 sortIndex 同一套算法（lib/sort-index.ts）。
  sortIndex Float    @default(0)
  /// 「重点项目」标记 + 顺序，用一个字段同时表达两层语义：
  ///  - null  → 未加星
  ///  - 非 null → 已加星，值就是在「重点项目区」内的浮点排序键
  /// 重点区与普通区拖拽互不影响（各自独立的 sortIndex），实现简单。
  starSortIndex Float?
  /// 所属分类。删除分类前必须先把项目迁走，DB 用 Restrict 兜底；
  /// API 层 DELETE 分类时会自动迁到默认分类后再删。
  categoryId String
  category   ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]

  @@index([archived, sortIndex])
  @@index([categoryId, sortIndex])
}

model Task {
  id             String   @id @default(cuid())
  title          String
  description    String?  // markdown
  projectId      String
  assigneeId     String?
  creatorId      String

  // "todo" | "doing" | "blocked" | "done" | "canceled"
  // done / canceled 都是「终态」：done = 做完了（算业绩），canceled = 不做了（中止，不算业绩）。
  status         String   @default("todo")

  // 个人执行顺序（浮点排序键）。拖拽时设为相邻两项的均值。
  // 作用域可视为"该 assignee 的全部任务"，跨视图共享一份顺序。
  sortIndex      Float    @default(0)

  focusedToday   Boolean  @default(false)
  blockedReason  String?
  dueDate        DateTime?
  // 任务被切换为 done 状态时由 API 写入；切回非 done 时清空。
  // 不要依赖 updatedAt 判断"今日完成"——updatedAt 会被任何字段编辑触发。
  completedAt    DateTime?
  // 任务被切换为 canceled（已取消）时由 API 写入；切回非 canceled 时清空。
  // 与 completedAt 互斥：一个任务不会既完成又取消（API 切换时会清掉对方）。
  canceledAt     DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee  User?      @relation("Assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator   User       @relation("Creator", fields: [creatorId], references: [id])
  yuqueLinks YuqueLink[]

  @@index([assigneeId, sortIndex])
  @@index([projectId, status])
  @@index([status])
}

model YuqueLink {
  id        String   @id @default(cuid())
  taskId    String
  url       String
  title     String?  // 可缓存语雀文档标题
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

/// 任务状态的日级快照。team page 的「进行中 / 阻塞 / 待办」需要历史趋势，
/// 而这些是当前状态字段、本身不可回放；所以每次访问 /team 时 upsert 当天一条，
/// 累积形成 sparkline 数据。
///
/// 设计要点：
///  - `date` 用本地零点对齐（new Date(y, m, d)），既是主键也是查询索引
///  - 没有 cron 框架，依赖访问触发；某天没人访问就缺一条，前端做插值补齐
///  - 字段只保留 4 个状态计数；不耦合 user / project 维度，保持表小、写入快
model DailyStatusSnapshot {
  date      DateTime @id
  doing     Int      @default(0)
  blocked   Int      @default(0)
  todo      Int      @default(0)
  done      Int      @default(0)
  updatedAt DateTime @updatedAt
}
