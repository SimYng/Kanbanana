# ============================================================
# SQLite 数据库路径
# 重要：Prisma 的 file: 协议相对路径是「相对 schema.prisma 所在目录」解析的
# 本地开发：file:./dev.db    → 实际落在 prisma/dev.db
# Docker：  file:/app/data/kanbanana.db（已挂载为 volume）
# ============================================================
DATABASE_URL="file:./dev.db"

# NextAuth 必填：随机字符串，至少 32 字符
# 生成方法：openssl rand -base64 32
NEXTAUTH_SECRET="please-change-me-to-a-random-32-char-secret"

# 应用访问地址。本地开发用 http://localhost:3000；
# 部署到内网服务器时改为实际访问地址（含协议+端口）
NEXTAUTH_URL="http://localhost:3000"

# 初始管理员账号（仅在 seed 脚本里使用，可改）
ADMIN_EMAIL="admin@local"
ADMIN_PASSWORD="admin123"
